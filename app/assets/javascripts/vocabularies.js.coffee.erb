# All this logic will automatically be available in application.js.
# You can use CoffeeScript in this file: http://coffeescript.org/

vocabulary_words = []
current_word = {}
changed = false
disabledLinks = true
durations = [
  '<%= Note::VOCAB_REVIEW_INTERVAL_0 %> days',
  '<%= Note::VOCAB_REVIEW_INTERVAL_1 %> days',
  '<%= Note::VOCAB_REVIEW_INTERVAL_2 %> days',
  '<%= Note::VOCAB_REVIEW_INTERVAL_3 %> days',
  '<%= Note::VOCAB_REVIEW_INTERVAL_4 %> days',
  '<%= Note::VOCAB_REVIEW_INTERVAL_5 %> days'
]
meta_language_voice = false
meta_language_voice_rate = false
meta_audio_rate = false
after = false

setRating = (rating) ->
  current_word['rating'] = rating
  changed = true
  $('#word').attr 'class', ''
  $('#word').addClass "s#{current_word['rating']}"
  $('#buttons span.w').css('opacity', 0.5)
  $("#buttons .s#{current_word['rating']}").css('opacity', 1)
  $('#correctAnswer').attr('title', "Will show up in #{durations[rating]} again.")

disableButtons = ->
  disabledLinks = true

enableButtons = ->
  disabledLinks = false

refreshVocabulary = ->
  after = false
  $('#exampleSentence').html ''
  $('#vocabButtons #after').fadeOut 300, ->
    $('#vocabButtons #before').fadeIn 300
  $('#note').fadeTo 300, 0
  $('#note').css('visibility', 'hidden')
  $('#word').fadeTo 300, 0, ->
    $('#buttons').fadeTo 0, 0
    language = $('#meta_language').html().toLowerCase()
    changed = false
    $.getJSON "/vocabulary/#{language}.json", (data) ->
      vocabulary_words = data
      $('#count').html vocabulary_words.length
      if vocabulary_words.length == 0
        $('#no-vocab').show()
        $('#vocab').hide()
      else
        $('#vocab').show()
        $('#no-vocab').hide()
        # if we still have more than one word, lets not do the last word again
        if vocabulary_words.length > 1
          index = vocabulary_words.indexOf(current_word.value)
          vocabulary_words.splice(index, 1)

        max = Math.min(50, vocabulary_words.length)
        p = vocabulary_words[Math.floor(Math.random() * max)]
        $.getJSON "/words/#{language}/#{p}", (data) ->
          current_word = data
          $('#wordvalue').html current_word['value']
          $('.toggleVocabulary').attr 'value', current_word['value']
          $('.toggleVocabulary').removeClass 'fa-minus'
          $('.toggleVocabulary').addClass 'fa-check'
          $('#word').html current_word['value_clean']
          $('#note').html current_word['note']
          $('#word').fadeTo 300, 1
          setRating current_word['rating']
          enableButtons()

speak = (text) ->
  meta_language_voice = $('#meta_language_voice').html()
  meta_language_voice_rate = $('#meta_language_voice_rate').html()
  meta_audio_rate = $('#meta_audio_rate').html()
  if meta_language_voice != '' and text != '' and meta_audio_rate > 0
    rate = parseFloat(meta_language_voice_rate * (meta_audio_rate/100))
    responsiveVoice.speak text, meta_language_voice, { rate: rate }

$ ->
  if ($('body').attr('data-controller') != 'vocabularies') || ($('body').attr('data-action') != 'index')
    return
  language = $('#meta_language').html().toLowerCase()
  refreshVocabulary()

  $('#vocab h1').mouseover ->
    return if disabledLinks
    $('#buttons').fadeTo 300, 1

  $('#showAnswer').click ->
    return if disabledLinks
    disableButtons()
    $('#note').css('visibility', 'visible')
    $('#note').fadeTo 500, 1
    $('#vocabButtons #before').fadeOut 300, ->
      $('#vocabButtons #after').fadeIn(300)
    after = true
    enableButtons()
    speak current_word['value']

  $('#word').click ->
    return if disabledLinks
    disableButtons()
    wordvalue = $('#wordvalue').html().toLowerCase()
    $.getJSON "/words/#{language}/#{wordvalue}/sentence", (data) ->
      $('#exampleSentence').html "<blockquote>#{data['value']}</blockquote>"
      enableButtons()
    speak current_word['value'] if after

  $('#correctAnswer').click ->
    return if disabledLinks
    disableButtons()
    wordvalue = $('#wordvalue').html().toLowerCase()
    $.ajax
      type: 'PATCH'
      url: '/words/' + wordvalue
      data:
        'word[language]': language
        'word[reviewed]': true
      async: false
    refreshVocabulary()

  $('#incorrectAnswer').click ->
    return if disabledLinks
    disableButtons()
    refreshVocabulary()

  $('#buttons span.w').click ->
    return if disabledLinks
    rating = $(this).attr('value')
    setRating(rating)
    wordvalue = $('#wordvalue').html().toLowerCase()
    $.ajax
      type: 'PATCH'
      url: '/words/' + wordvalue
      data:
        'word[language]': language
        'word[rating]': rating
      async: true
