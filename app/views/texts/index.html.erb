<% if selected_language == nil %>
  <% content_for :title, 'Texts' %>
<% else %>
  <% content_for :title, '%s Texts' % [selected_language.name] %>
<% end %>

<% selection = if selected_language then selected_language.name else nil end %>

<div class="row">
  <div class="two-thirds column">
    <h4>
      <% if selected_language %>
        <%= selected_language.name %>
      <% end %>
      Texts
      <% if @hidden %>
        (Archived)
      <% end %>
      <% if @public %>
        (Public)
      <% end %>
      </h4>
  </div>
  <div class="one-third column" style="text-align: right; vertical-align: middle;">
    <% if selected_language != nil %>
      <a href="/texts" class="toggle-link">
        <%= fa_icon 'language' %> Other Languages
      </a>
    <% end %>
  </div>
</div>

<div class="row">
  <div class="two-thirds column">
    <% if selected_language == nil %>

      <% op = language_options(true).map { |l| l[0] } %>
      <h6 class="docs-header">Select Language:</h6>
      <p>
        <div class="row">
          <% @languages.in_groups(4, false).to_a.each { |splice| %>
            <div class="three columns">
              <% splice.each { |lang| %>
                <% l = if not op.include? lang.name then "button-gray" else "" end %>
                <%= link_to lang.name, '/texts/' + lang.name.downcase, class: 'button u-full-width ' + l %>
              <% } %>
            </div>
          <% } %>
        </div>
      </p>
      <h6 class="docs-header">How to Read?</h6>
      <p>In this section of the website you can add and read texts which you are interested in reading. Just pick the language you are interested in studying from the list and begin to add some texts or look through the publically available texts.</p>
      <p>If you need material, look for easy texts online, try to read news or maybe the lyrics to your favorite song. Many classical texts are available online, or you could try your hand at reading about interesting things from wikipedia. Or, if you want to keep it simple, you can add texts from your text book or class.</p>

    <% else %>

      <% if @texts == {} %>
        <% if @public %>
          <p>It appears that no public texts in <%= selected_language.name %> have been added yet.</p>
        <% elsif not @hidden %>
          <p>It seems like you have not yet added any texts in <%= selected_language.name %> yet. Please feel free to add some that interest you. If you need inspiration, try looking online for newspapers, short stories, song lyrics or other media.</p>
        <% else %>
          <p>You seem to not have any archived texts in <%= selected_language.name %>.</p>
        <% end %>

      <% end %>
      <%
        last_category = nil
        category_id = 0
        @texts.each do |category, texts|
          category_id += 1
          total_words = texts.map { |t| t.word_count }.inject(:+)
      %>
        <table class="u-full-width">
          <thead>
            <th colspan="2"><%= category %></th>
            <th style="text-align: right">
              <alias title="Total number of words in the category">
                <%= number_with_precision total_words, precision: 0, delimiter: ',' %>
              </alias>
            </th>
          </thead>
          <tbody>
            <% text_count = 0 %>
            <% max_text_count = 5 %>
            <% texts.each do |text| %>
              <% text_count += 1 %>

              <% if text_count <= max_text_count %>
                <tr>
              <% else %>
                <tr style="display: none;" class="cat-<%= category_id %>">
              <% end %>

                <td class="centered" style="width: 2.5em; padding-right: 0">
                  <% if text.public %>
                    <alias title="This is a public text. Make a copy for you to see its status."><%= fa_icon 'star-o' %></alias>
                  <% elsif current_user.native_language_id == selected_language.id %>
                    <alias title="This is your native language, you should know all the words ;)"><%= fa_icon 'check' %></alias>
                  <% elsif not text.completed %>
                    <alias title="Not all words in this text have been rated yet."><%= fa_icon 'minus' %></alias>
                  <% else %>
                    <alias title="You have worked through this text and rated all the words within it."><%= fa_icon 'check' %></alias>
                  <% end %>
                </td>
                <td style="padding-left: 0">
                  <%= link_to text.title, text_path(text) %>
                </td>
                <td style="text-align: right">
                  <alias title="Number of words in the text">
                    <%= number_with_precision text.word_count, precision: 0, delimiter: ',' %>
                  </alias>
                </td>
              </tr>
            <% end %>
            <% if text_count > max_text_count %>
              <tr>
                <td colspan="3" class="centered" style="border-bottom: none;">
                  <a href="#" class="showMoreText" value="<%= category_id %>">
                    Show <%= text_count - max_text_count %> more <%= "text".pluralize(text_count - max_text_count) %>
                  </a>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    <% end %>
  </div>
  <div class="one-third column">
    <% new_url = if selected_language then "/texts/" + selected_language.name.downcase + "/new" else new_text_path end %>
    <% if selection == nil %>
      <%= image_tag "globe.png", class: "u-full-width" %>
    <% else %>
      <%= link_to fa_icon("plus") + ' Add New', new_url, class: 'button button-primary u-full-width', title: 'Add a new text' %>
    <% end %>

    <% if selected_language and not @public %>

      <%= link_to fa_icon("users") + ' Show Public Texts', "/texts/" + selected_language.name.downcase + "/public", class: 'button u-full-width', title: 'Show public texts.' %>

      <% if selected_language and not @hidden %>
        <%= link_to fa_icon("folder-open-o") + ' Show Archived Texts', "/texts/" + selected_language.name.downcase + "/archive", class: 'button u-full-width', title: 'Show archived texts.' %>
      <% elsif selected_language and @hidden %>
        <%= link_to fa_icon("file-text-o") + ' Show Active Texts', "/texts/" + selected_language.name.downcase, class: 'button u-full-width', title: 'Show currently active texts.' %>
      <% end %>

    <% elsif selected_language and @public %>

      <%= link_to fa_icon("user") + ' Show Private Texts', "/texts/" + selected_language.name.downcase, class: 'button u-full-width', title: 'Show your private texts.' %>

    <% end %>

    <% if selected_language != nil %>

      <% if @word_count == 0 %>
        <p>You have no words marked as <alias title="Rated at three or higher">known</alias> in <%= selected_language.name %> yet, but why not get it started right away and try to work on that?</p>
      <% else %>
         <p>
          You have already added <%= number_with_precision @word_count, precision: 0, delimiter: ',' %> <%= selected_language.name %> words, of which <%= number_with_precision @known_word_count, precision: 0, delimiter: ',' %> should be more or less '<alias title="Rated at three or higher">familiar</alias>' to you.<br /><b><%= @compliment %></b>
          </p>
      <% end %>

      <% if @total_text_count == 0 %>
        <p>You have not added any <%= selected_language.name %> texts to the website yet, but feel free to add <%= link_to 'add one', new_text_path %> if you want.</p>
      <% else %>
        <p>You have already added <%= pluralize(@total_text_count - @total_text_count_public, selected_language.name + " text") %> to the website, but feel free to add <%= link_to 'add a new one', new_text_path %> if you want.</p>
      <% end %>

    <% end %>
  </div>
</div>
