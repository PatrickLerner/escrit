<% if current_language == nil %>
  <% content_for :title, 'Texts' %>
<% else %>
  <% content_for :title, '%s Texts' % [current_language.name] %>
<% end %>

<%= render 'texts/header_language_choice', url: '/texts' %>

<%= render 'texts/header', page_title: "#{current_language.name} Texts", mini: false %>

<div class="row">
  <div class="nine columns">
    <div class="button-group">
      <% pr_class = 'button u-full-width' %>
      <% ar_class = 'button u-full-width' %>
      <% pu_class = 'button u-full-width' %>
      <% if @public %>
        <% pu_class += " button-primary" %>
      <% elsif @hidden %>
        <% ar_class += " button-primary" %>
      <% else %>
        <% pr_class += " button-primary" %>
      <% end %>
      <%= link_to 'Private', texts_path(current_language.name.downcase), title: 'Show currently active texts.', class: pr_class %>
      <%= link_to 'Archived', archived_texts_path(current_language.name.downcase), title: 'Show currently active texts.', class: ar_class %>
      <%= link_to 'Public', public_texts_path(current_language.name.downcase), title: 'Show currently active texts.', class: pu_class %>
    </div>
  </div>
  <div class="three columns">
    <%= link_to fa_icon('plus') + ' Add Text', new_text_path, title: 'Add a new text.', class: 'button button-primary u-full-width' %>
  </div>
</div>

<div class="row">
  <div class="two-thirds column">
    <% if @texts == [] %>
      <% if @public %>
        <p>It appears that no public texts in <%= current_language.name %> have been added yet.</p>
      <% elsif not @hidden %>
        <p>It seems like you have not yet added any texts in <%= current_language.name %>. Please feel free to add some that interest you. If you need inspiration, try looking online for newspapers, short stories, song lyrics or other media.</p>
      <% else %>
        <p>You seem to not have any archived texts in <%= current_language.name %>.</p>
      <% end %>
    <% end %>

    <%
      last_category = nil
      category_id = 0
      @texts.each do |category, texts|
        category_id += 1
        total_words = texts.map { |t| t.word_count }.inject(:+)
    %>
      <table class="u-full-width listing">
        <thead>
          <th colspan="2">
            <%= link_to category, edit_category_path(texts[0]), class: 'category_link' %>
          </th>
          <th style="text-align: right">
            <alias title="Total number of words in the category">
              <%= number_with_precision total_words, precision: 0, delimiter: ',' %>
            </alias>
          </th>
        </thead>
        <tbody>
          <% text_count = 0 %>
          <% max_text_count = 5 %>
          <% texts.each do |text| %>
            <% text_count += 1 %>

            <% if text_count <= max_text_count %>
              <tr>
            <% else %>
              <tr style="display: none;" class="cat-<%= category_id %>">
            <% end %>

              <td class="centered" style="width: 2.5em; padding-right: 0">
                <% if text.public %>
                  <alias title="This is a public text. Make a copy for you to see its status."><%= fa_icon 'star' %></alias>
                <% elsif current_user.native_language_id == current_language.id %>
                  <alias title="This is your native language, you should know all the words ;)"><%= fa_icon 'check' %></alias>
                <% elsif not text.completed %>
                  <alias title="Not all words in this text have been rated yet."><%= fa_icon 'minus' %></alias>
                <% else %>
                  <alias title="You have worked through this text and rated all the words within it."><%= fa_icon 'check' %></alias>
                <% end %>
              </td>
              <td style="padding-left: 0">
                <%= link_to text.title, text_path(text) %>
              </td>
              <td style="text-align: right">
                <alias title="Number of words in the text">
                  <%= number_with_precision text.word_count, precision: 0, delimiter: ',' %>
                </alias>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <% if text_count > max_text_count %>
          <div class="centered">
            <a href="#" class="showMoreText" value="<%= category_id %>">
              Show <%= text_count - max_text_count %> more <%= "text".pluralize(text_count - max_text_count) %>
            </a>
          </div>
      <% end %>
    <% end %>
  </div>
  <div class="one-third column" style="text-align: right;">
    <h5>Your Stats</h5>

    <div class="row no-wrap sidebar-counter">
      <div class="one-half column">
        <h4>
          <%= number_with_precision @word_count, precision: 0, delimiter: ',' %>
        </h4>
        <span>
          <%= "word".pluralize @word_count %> added.
        </span>
      </div>
      <div class="one-half column">
        <h4>
          <%= number_with_precision @known_word_count, precision: 0, delimiter: ',' %>
        </h4>
        <span>
          <alias title="Words with a rating of three or above are considered familiar. That is, you probably remember them more often than you forget them.">familiar <%= "word".pluralize @known_word_count %></alias>.
        </span>
      </div>
    </div>

    <div class="row no-wrap sidebar-counter">
      <div class="one-half column">
        <h4>
          <%= number_with_precision @total_text_count, precision: 0, delimiter: ',' %>
        </h4>
        <span>
          <%= "text".pluralize @total_text_count %> added.
        </span>
      </div>
      <div class="one-half column">
        <h4>
          <%= number_with_precision @total_text_count_read, precision: 0, delimiter: ',' %>
        </h4>
        <span>
          <%= "text".pluralize @total_text_count_read %> read.
        </span>
      </div>
    </div>

    <% if @word_count > 0 %>
      <div style="margin-top: 0.5em;">
        <b><%= @compliment %></b>
      </div>
    <% end %>
  </div>
</tr>
