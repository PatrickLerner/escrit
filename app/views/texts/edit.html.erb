<% content_for :title, 'Edit Text' %>

<%= render 'texts/header', page_title: "Edit #{current_language.name} Text", mini: true %>

<% if @text.errors.any? %>
  <div id="error_explanation">
    <h5>
      <%= pluralize(@text.errors.count, "error") %> prohibited
      this text from being saved:
    </h5>
    <ul>
      <% @text.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_for :text, url: text_path(@text), html: { method: :patch, class: 'text_form' } do |f| %>
  <div class="row">
    <div class="six columns">
      <%= f.label :title, 'Titel' %>
      <%= f.text_field :title, class: 'u-full-width', placeholder: 'Titel', autocomplete: :off %>
    </div>
    <div class="six columns">
      <%= f.label :category, 'Category' %>
      <%= f.text_field :category, class: 'u-full-width', placeholder: 'Category', autocomplete: :off %>
    </div>
  </div>

  <%= f.label :content, 'Content (<span id="character_count">0</span> / 10,000)'.html_safe %>
  <%= f.text_area :content, class: 'u-full-width', placeholder: 'Content' %>

  <%= f.check_box :hidden, style: 'display: none' %>
  <%= f.check_box :public, style: 'display: none' %>
  <%= f.text_field :language_id, value: current_language.id, style: 'display: none' %>

  <div class="row">
    <div class="six columns">
      <div class="row no-wrap" style="margin-bottom: 1em;">
        <div class="six columns">
          <a href="#" id="archiveToggle" class="toggle-link">
            <%= fa_icon("toggle-off") %> Archive this text
          </a>
        </div>
        <div class="six columns">
          <% if current_user.admin? %>
            <a href="#" id="publicToggle" class="toggle-link">
              <%= fa_icon("toggle-off") %> Make text public
            </a>
          <% end %>
        </div>
      </div>
    </div>
    <div class="three columns">
      <%= link_to fa_icon("chevron-left") + ' Back', text_path(@text), class: 'button u-full-width', title: 'Go back to overview' %>
    </div>
    <div class="three columns">
      <%= link_to fa_icon("floppy-o") + ' Save Text', '', :class => 'button button-primary u-full-width', :onclick => "$('.text_form').submit(); return false;" %>
      <%= link_to fa_icon("times") + " Delete", text_path(@text), method: :delete, data: { confirm: 'Are you absolutely certain?' }, title: 'Delete', class: 'button u-full-width button-delete' %>
    </div>
  </div>
<% end %>

<span id="meta_language" style="display: none;"><%= current_language.name %></span>
