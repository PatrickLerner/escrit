<% content_for :title, 'Settings' %>

<h1>Settings</h1>

<div class="row">
  <div class="two-thirds column">
    <div class="row">
      <div class="one-half column centered">
        <a href="/services" class="button u-full-width"><%= fa_icon("cogs") %> Services</a>
      </div>
      <div class="one-half column centered">
        <a href="/u/<%= current_user.id %>" class="button u-full-width"><%= fa_icon("user") %> User Profile</a>
      </div>
    </div>

    <% if current_user.admin? %>
      <p><center><h4>Admin Settings</h4></center></p>
      <div class="row">
        <div class="one-half column centered">
          <a href="/compliments" class="button u-full-width"><%= fa_icon("heart") %> Compliments</a>
          <a href="/languages" class="button u-full-width"><%= fa_icon("flag") %> Languages</a>
        </div>
        <div class="one-half column centered">
          <a href="/replacements" class="button u-full-width"><%= fa_icon("magic") %> Replacements</a>
        </div>
      </div>
    <% end %>
  </div>
  <div class="one-third column centered">
    <%= image_tag "book.png", :class => "p80 no-border" %>
  </div>
</div>
