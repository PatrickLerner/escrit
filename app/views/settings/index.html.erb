<% content_for :title, 'Settings' %>

<h4>Settings</h4>

<div class="row">
  <div class="two-thirds column">
    <div class="row">
      <div class="one-half column">
        <a href="<%= edit_user_registration_path %>" class="button u-full-width"><%= fa_icon("user") %> User Profile</a>
      </div>
      <div class="one-half column">
        <a href="/services" class="button u-full-width"><%= fa_icon("cogs") %> Services</a>
      </div>
      <div class="one-third column">
      </div>
    </div>

    <p><h5>Additional Tools</h5></p>
    <div class="row">
      <div class="one-half column">
        <a href="/words" class="button u-full-width"><%= fa_icon("list") %> List of Words</a>
      </div>
      <div class="one-half column">
      </div>
    </div>

    <% if current_user.admin? %>
      <p><h5>Admin Settings</h5></p>
      <div class="row">
        <div class="one-half column">
          <a href="/languages" class="button u-full-width"><%= fa_icon("flag") %> Languages</a>
        </div>
        <div class="one-half column">
          <a href="/compliments" class="button u-full-width"><%= fa_icon("heart") %> Compliments</a>
        </div>
      </div>
    <% end %>
  </div>
  <div class="one-third column">
    <%= image_tag "grandma-storytelling.png", :class => "u-full-width no-border" %>
  </div>
</div>
