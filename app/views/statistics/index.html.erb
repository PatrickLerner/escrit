<% content_for :title, 'Statistics' %>

<h4>Statistics</h4>

<div class="row">
  <div class="two-thirds column">
    <h5>New Words Added (Per Week)</h5>
    <canvas id="newWords"></canvas>
    <ul>
      <li>In the last <%= pluralize(@new_words_count, "week") %> you added on average <%= number_with_precision(@new_words_average, precision: 2) %> new words per week.</li>
      <li>In your best week in the last <%= @new_words_data.count %> weeks, you added <%= @new_words_data.max %> new words.</li>
    </ul>

    <h5>New Texts Added (Per Week)</h5>
    <canvas id="newTexts"></canvas>
    <ul>
      <li>In the last <%= pluralize(@new_texts_count, "week") %> you added on average <%= number_with_precision(@new_texts_average, precision: 2) %> new texts per week.</li>
      <li>In your best week in the last <%= @new_texts_data.count %> weeks, you added <%= @new_texts_data.max %> new texts.</li>
    </ul>

    <h5>Words (by Rating)</h5>
    <canvas id="words"></canvas>
  </div>
  <div class="one-third column">
    <% selection = if selected_language then selected_language.name else nil end %>
    <% if language_options(true).count > 0 %>
     <label for="language_statistics">Filter by Language:</label>
     <%= select_tag :language_statistics, options_for_select(['All'] + language_options(true).map { |k| k[0] }, selected: selection), class: 'u-full-width' %>
    <% end %>
    <%= image_tag "typewriter.png", :class => "u-full-width no-border" %>
  </div>
</div>

<script type="text/javascript">
    var newWordsData = {
        labels: [<%= @new_words_labels.map{|i| '"' + i + '"'}.join(',').html_safe %>],
        datasets: [
            {
                label: "Number of Words",
                fillColor: "rgba(33, 47, 63,0.9)",
                strokeColor: "rgba(33, 47, 63,1)",
                pointColor: "rgba(33, 47, 63,1)",
                pointStrokeColor: "#fff",
                pointHighlightFill: "#fff",
                pointHighlightStroke: "rgba(151,187,205,1)",
                data: [<%= @new_words_data.join ',' %>]
            }
        ]
    };
    var newWordsCtx = $("#newWords").get(0).getContext("2d");

    var newTextsData = {
        labels: [<%= @new_texts_labels.map{|i| '"' + i + '"'}.join(',').html_safe %>],
        datasets: [
            {
                label: "Number of Texts",
                fillColor: "rgba(33, 47, 63,0.9)",
                strokeColor: "rgba(33, 47, 63,1)",
                pointColor: "rgba(33, 47, 63,1)",
                pointStrokeColor: "#fff",
                pointHighlightFill: "#fff",
                pointHighlightStroke: "rgba(151,187,205,1)",
                data: [<%= @new_texts_data.join ',' %>]
            }
        ]
    };
    var newTextsCtx = $("#newTexts").get(0).getContext("2d");

    var wordsData = {
        labels: [<%= @words_labels.map{|i| '"' + i + '"'}.join(',').html_safe %>],
        datasets: [
            {
                label: "Number of Texts",
                fillColor: "rgba(33, 47, 63,0.9)",
                strokeColor: "rgba(33, 47, 63,1)",
                pointColor: "rgba(33, 47, 63,1)",
                pointStrokeColor: "#fff",
                pointHighlightFill: "#fff",
                pointHighlightStroke: "rgba(151,187,205,1)",
                data: [<%= @words_data.join ',' %>]
            }
        ]
    };
    var wordsCtx = $("#words").get(0).getContext("2d");

    $(document).ready(function() {
        var htmlCanvas = document.getElementById('newWords'),
            context = htmlCanvas.getContext('2d');

        window.addEventListener('resize', resizeCanvas, false);
        resizeCanvas();

        function resizeCanvas() {
            var w = $('.two-thirds').innerWidth(),
                h = Math.round(w / 3 * 2);

            $("#newWords").css({"width" : w, "height": h});   
            $("#newTexts").css({"width" : w, "height": h});   
            $("#words").css({"width" : w, "height": h});   
            
            var newWordsChart = new Chart(newWordsCtx).Bar(newWordsData, {
                barStrokeWidth : 0,
                responsive: true,
                maintainAspectRatio: true
            });

            var newTextsChart = new Chart(newTextsCtx).Bar(newTextsData, {
                barStrokeWidth : 0,
                responsive: true,
                maintainAspectRatio: true
            });

            var wordsChart = new Chart(wordsCtx).Bar(wordsData, {
                barStrokeWidth : 0,
                responsive: true,
                maintainAspectRatio: true
            });
        }
    });
</script>
