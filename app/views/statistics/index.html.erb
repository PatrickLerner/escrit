<% content_for :title, "Statistics for #{current_language.name}" %>

<header class="large">
  <div class="image <%= current_language.name.downcase %>"></div>
  <div class="container">
    <h1>Statistics for <%= current_language.name %></h1>
    <h2>&nbsp;</h2>
  </div>
</header>

<div class="container">
  <div class="row">
    <div class="six columns">
      <h5>New Words Added (This Week)</h5>
      <canvas id="newWordsThisWeek"></canvas>
      <p>
        <div class="u-centered">
          You have added <%= number_with_precision @total_new_words_this_week, precision: 0, delimiter: ',' %> <%= "word".pluralize @total_new_words_this_week %> this week so far.
        </div>
      </p>
    </div>
    <div class="six columns">
      <h5>Words (by Rating)</h5>
      <canvas id="words"></canvas>
      <p>
        <% count = @words_data.each_with_index.map { |k, i| k.to_i * (i + 1) }.reduce(:+).to_f %>
        <% sum = @words_data.map{ |i| i.to_i }.reduce(:+).to_f %>
        <% average = if sum > 0 then count / sum else 0 end %>
        <div class="u-centered">
          You have rated a total of <%= number_with_precision sum, precision: 0, delimiter: ',' %> <%= "word".pluralize sum %>.
        </div>
        <div class="u-centered">
          The average rating of a word is: <%= number_with_precision(average, precision: 2) %>
        </div>
      </p>
    </div>
  </div>

  <h5>Completed Texts</h5>
  <p>
    <div class="u-centered">
      You have finished reading <%= number_with_precision @total_read_texts, precision: 0, delimiter: ',' %> <%= "text".pluralize @total_read_texts %> with a combined total word count of <%= number_with_precision @total_read_words, precision: 0, delimiter: ',' %> <%= "word".pluralize @total_read_words %> (can include words more than once).
    </div>
  </p>

  <div class="row">
    <div class="six columns">
      <h5>New Texts Added (Per Week)</h5>
      <canvas id="newTexts"></canvas>
      <p>
        <div class="u-centered">
          In the last <%= @new_words_data.count %> weeks:
        </div>
        <div class="u-centered">
          You added on average <%= number_with_precision(@new_texts_average, precision: 2, delimiter: ',') %> new texts per week.
        </div>
        <div class="u-centered">
          In your best week you added <%= number_with_precision @new_texts_data.max, precision: 0, delimiter: ',' %> new <%= "text".pluralize @new_texts_data.max %>.
        </div>
      </p>
    </div>
    <div class="six columns">
      <h5>New Words Added (Per Week)</h5>
      <canvas id="newWords"></canvas>
      <p>
        <div class="u-centered">
          In the last <%= @new_words_data.count %> weeks:
        </div>
        <div class="u-centered">
          On average you added <%= number_with_precision(@new_words_average, precision: 2, delimiter: ',') %> new words per week.
        </div>
        <div class="u-centered">
          In your best week you added <%= number_with_precision @new_words_data.max, precision: 0, delimiter: ',' %> new <%= "word".pluralize @new_words_data.max %>.
        </div>
      </p>
    </div>
  </div>

  <script type="text/javascript">
    var fontFamily = "'Raleway', 'Helvetica Neue', 'Helvetica', 'Arial'";
    Chart.defaults.global.scaleFontFamily = fontFamily;
    Chart.defaults.global.tooltipFontFamily = fontFamily;
    Chart.defaults.global.tooltipTitleFontFamily = fontFamily;
    Chart.defaults.global.pointLabelFontFamily = fontFamily;
    Chart.defaults.global.scaleLabel = "<%%= '  ' + value%>";

    Chart.defaults.global.tooltipFillColor = "#2D3142";
    Chart.defaults.global.tooltipFontColor = "#fff";
    Chart.defaults.global.tooltipTemplate = "<%%if (label){%><%%=label%>: <%%}%><%%= value.toLocaleString('en-US') %>";

    var newWordsThisWeekData = {
      labels: [<%= @new_words_this_week_labels.map{|i| '"' + i + '"'}.join(',').html_safe %>],
      datasets: [
        {
          label: "Number of Words",
          fillColor: "#17A4A2",
          strokeColor: "#15A19F",
          data: [<%= @new_words_this_week_data.join ',' %>]
        }
      ]
    };
    var newWordsThisWeekCtx = $("#newWordsThisWeek").get(0).getContext("2d");

    var newWordsData = {
      labels: [<%= @new_words_labels.map{|i| '"' + i + '"'}.join(',').html_safe %>],
      datasets: [
        {
          label: "Number of Words",
          fillColor: "#17A4A2",
          strokeColor: "#15A19F",
          data: [<%= @new_words_data.join ',' %>]
        }
      ]
    };
    var newWordsCtx = $("#newWords").get(0).getContext("2d");

    var newTextsData = {
      labels: [<%= @new_texts_labels.map{|i| '"' + i + '"'}.join(',').html_safe %>],
      datasets: [
        {
          label: "Number of Texts",
          fillColor: "#17A4A2",
          strokeColor: "#15A19F",
          data: [<%= @new_texts_data.join ',' %>]
        }
      ]
    };
    var newTextsCtx = $("#newTexts").get(0).getContext("2d");

    var wordsData = [
      {
        value: <%= @words_data[0] %>,
        color: '#F9C889',
        label: '1 (Looked it up once)'
      },
      {
        value: <%= @words_data[1] %>,
        color: '#FFF391',
        label: '2 (This time I\'ll remember it)'
      },
      {
        value: <%= @words_data[2] %>,
        color: '#CAF3A4',
        label: '3 (I\'m getting it now)'
      },
      {
        value: <%= @words_data[3] %>,
        color: '#D0E1F2',
        label: '4 (Seems easy at this point)'
      },
      {
        value: <%= @words_data[4] %>,
        color: '#eee',
        label: '5 (Know it in my sleep)'
      }
    ];
    /*{
      labels: [<%= @words_labels.map{|i| '"' + i + '"'}.join(',').html_safe %>],
      datasets: [
        {
          label: "Number of Texts",
          fillColor: "#17A4A2",
          strokeColor: "#15A19F",
          data: [<%= @words_data.join ',' %>]
        }
      ]
    };*/
    var wordsCtx = $("#words").get(0).getContext("2d");

    $(document).ready(function() {
      var htmlCanvas = document.getElementById('newWords'),
          context = htmlCanvas.getContext('2d');

      window.addEventListener('resize', resizeCanvas, false);
      resizeCanvas();

      function resizeCanvas() {
        var w = $('h5').innerWidth(),
            h = Math.max(230, Math.round(w / 6 * 4));

        $("#newWords").css({"width" : w, "height": h});
        $("#newWordsThisWeek").css({"width" : w, "height": h});
        $("#newTexts").css({"width" : w, "height": h});
        $("#words").css({"width" : w, "height": h});

        var newWordsChart = new Chart(newWordsCtx).Bar(newWordsData, {
          barStrokeWidth : 0,
          responsive: true,
          maintainAspectRatio: true
        });

        var newWordsThisWeekChart = new Chart(newWordsThisWeekCtx).Bar(newWordsThisWeekData, {
          barStrokeWidth : 0,
          responsive: true,
          maintainAspectRatio: true
        });

        var newTextsChart = new Chart(newTextsCtx).Bar(newTextsData, {
          barStrokeWidth : 0,
          responsive: true,
          maintainAspectRatio: true
        });

        var wordsChart = new Chart(wordsCtx).Doughnut(wordsData, {
          barStrokeWidth : 0,
          responsive: true,
          maintainAspectRatio: true
        });
        /*new Chart(wordsCtx).Bar(wordsData, {
          barStrokeWidth : 0,
          responsive: true,
          maintainAspectRatio: true
        });*/
      }
    });
  </script>
</div>
