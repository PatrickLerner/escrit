- content_for :title, "Statistics for #{current_language.name}"
- content_for :header_image_style, current_language.current_artwork_style
- content_for :header_title, 'Statistics'
- content_for :header_subtitle, current_language.name

.container
  .row
    .six.columns
      h5 New Words Added (This Week)
      canvas#newWordsThisWeek
      p
        .u-centered
          | You have added
          =<> number_with_precision @new_words_this_week.sum, precision: 0, delimiter: ','
          =<> "word".pluralize @new_words_this_week.sum
          | this week so far.
    .six.columns
      h5 Words (by Rating)
      canvas#words
      p
        - count = @total_words.data.each_with_index.map { |k, i| k.to_i * (i + 1) }.reduce(:+).to_f
        - sum = @total_words.sum.to_f
        - average = if sum > 0 then count / sum else 0 end
        .u-centered
          | You have rated a total of
          =<> number_with_precision sum, precision: 0, delimiter: ','
          =<> "word".pluralize sum
          | .
        .u-centered
          | The average rating of a word is:
          =< number_with_precision(average, precision: 2)
  h5 Completed Texts
  p
    .u-centered
      | You have finished reading
      =<> number_with_precision @total_read_texts, precision: 0, delimiter: ','
      =<> "text".pluralize @total_read_texts
      | with a combined total word count of
      =<> number_with_precision @total_read_words, precision: 0, delimiter: ','
      =<> "word".pluralize @total_read_words
      | (can include words more than once).
  .row
    .six.columns
      h5 New Texts Added (Per Week)
      canvas#newTexts
      p
        .u-centered
          | In the last
          =<> @new_words.data.count
          | weeks:
        .u-centered
          | You added on average
          =<> number_with_precision(@new_texts_average, precision: 2, delimiter: ',')
          | new texts per week.
        .u-centered
          | In your best week you added
          =<> number_with_precision @new_text.data.max, precision: 0, delimiter: ','
          | new
          =< "text".pluralize @new_text.data.max
          | .
    .six.columns
      h5 New Words Added (Per Week)
      canvas#newWords
      p
        .u-centered
          | In the last
          =<> @new_words.data.count
          | weeks:
        .u-centered
          | On average you added
          =<> number_with_precision(@new_words.average, precision: 2, delimiter: ',')
          | new words per week.
        .u-centered
          | In your best week you added
          =<> number_with_precision @new_words.data.max, precision: 0, delimiter: ','
          | new
          =< "word".pluralize @new_words.data.max
          | .
  .row
    .six.columns
      h5 Vocabulary for review
      canvas#vocabulary
      #vocabularyLegend
      p
        .u-centered
          | In total you have
          =<> number_with_precision @total_vocabulary_words, precision: 0, delimiter: ','
          =<> 'word'.pluralize @total_vocabulary_words
          | in your vocabulary.

javascript:
  var fontFamily = "'Raleway', 'Helvetica Neue', 'Helvetica', 'Arial'";
  Chart.defaults.global.scaleFontFamily = fontFamily;
  Chart.defaults.global.tooltipFontFamily = fontFamily;
  Chart.defaults.global.tooltipTitleFontFamily = fontFamily;
  Chart.defaults.global.pointLabelFontFamily = fontFamily;
  Chart.defaults.global.scaleLabel = "<%= '  ' + value%>";

  Chart.defaults.global.tooltipFillColor = "#2D3142";
  Chart.defaults.global.tooltipFontColor = "#fff";
  Chart.defaults.global.tooltipTemplate = "<%if (label){%><%=label%>: <%}%><%= value.toLocaleString('en-US') %>";

  var newWordsThisWeekData = {
    labels: #{@new_words_this_week.labels.to_json.html_safe},
    datasets: [
      {
        label: "Number of Words",
        fillColor: "#17A4A2",
        strokeColor: "#15A19F",
        data: #{@new_words_this_week.data.to_json.html_safe}
      }
    ]
  };
  var newWordsThisWeekCtx = $("#newWordsThisWeek").get(0).getContext("2d");

  var newWordsData = {
    labels: #{@new_words.labels.to_json.html_safe},
    datasets: [
      {
        label: "Number of Words",
        fillColor: "#17A4A2",
        strokeColor: "#15A19F",
        data: #{@new_words.data.to_json.html_safe}
      }
    ]
  };
  var newWordsCtx = $("#newWords").get(0).getContext("2d");

  var newTextsData = {
    labels: #{@new_text.labels.to_json.html_safe},
    datasets: [
      {
        label: "Number of Texts",
        fillColor: "#17A4A2",
        strokeColor: "#15A19F",
        data: #{@new_text.data.to_json.html_safe}
      }
    ]
  };
  var newTextsCtx = $("#newTexts").get(0).getContext("2d");

  var wordsData = [
    {
      value: #{@total_words.data[0]},
      color: '#F9C889',
      label: '1 (Looked it up once)'
    },
    {
      value: #{@total_words.data[1]},
      color: '#FFF391',
      label: '2 (This time I\'ll remember it)'
    },
    {
      value: #{@total_words.data[2]},
      color: '#CAF3A4',
      label: '3 (I\'m getting it now)'
    },
    {
      value: #{@total_words.data[3]},
      color: '#D0E1F2',
      label: '4 (Seems easy at this point)'
    },
    {
      value: #{@total_words.data[4]},
      color: '#eee',
      label: '5 (Know it in my sleep)'
    }
  ];
  var wordsCtx = $("#words").get(0).getContext("2d");

  var vocabularyData = {
    labels: #{@vocabulary.labels.to_json.html_safe},
    legendTemplate : "<ul class=\"<%=name.toLowerCase()%>-legend\"><% for (var i=0; i<datasets.length; i++){%><li><span style=\"background-color:<%=datasets[i].strokeColor%>\"></span><%if(datasets[i].label){%><%=datasets[i].label%><%}%></li><%}%></ul>",
    datasets: [
      {
        label: "Number of words for reviews",
        fillColor: "#71A5B7",
        strokeColor: "#71A5B7",
        data: #{@vocabulary.data.to_json.html_safe}
      },
      {
        label: "Number of words for reviews (cumulative)",
        fillColor: "#17A4A2",
        strokeColor: "#15A19F",
        data: #{@vocabulary_c.data.to_json.html_safe}
      }
    ]
  };
  var vocabularyCtx = $("#vocabulary").get(0).getContext("2d");

  $(document).ready(function() {
    var htmlCanvas = document.getElementById('newWords'),
        context = htmlCanvas.getContext('2d');

    window.addEventListener('resize', resizeCanvas, false);
    resizeCanvas();

    function resizeCanvas() {
      var w = $('h5').innerWidth(),
          h = Math.max(230, Math.round(w / 6 * 4));

      $("#newWords").css({"width" : w, "height": h});
      $("#newWordsThisWeek").css({"width" : w, "height": h});
      $("#newTexts").css({"width" : w, "height": h});
      $("#words").css({"width" : w, "height": h});

      var newWordsChart = new Chart(newWordsCtx).Bar(newWordsData, {
        barStrokeWidth : 0,
        responsive: true,
        maintainAspectRatio: true
      });

      var newWordsThisWeekChart = new Chart(newWordsThisWeekCtx).Bar(newWordsThisWeekData, {
        barStrokeWidth : 0,
        responsive: true,
        maintainAspectRatio: true
      });

      var newTextsChart = new Chart(newTextsCtx).Bar(newTextsData, {
        barStrokeWidth : 0,
        responsive: true,
        maintainAspectRatio: true
      });

      var wordsChart = new Chart(wordsCtx).Doughnut(wordsData, {
        barStrokeWidth : 0,
        responsive: true,
        maintainAspectRatio: true
      });

      var vocabularyChart = new Chart(vocabularyCtx).Bar(vocabularyData, {
        barStrokeWidth : 0,
        responsive: true,
        maintainAspectRatio: true
      });
      $("#vocabularyLegend").html(vocabularyChart.generateLegend());
    }
  });

