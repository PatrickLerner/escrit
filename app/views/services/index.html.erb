<% content_for :title, 'Services' %>

<h4>List of Services</h4>

<div class="row">
  <div class="two-thirds column">
    <table class="u-full-width">
      <tr>
        <th>Name</th>
        <th>Short Name</th>
        <th>Language</th>
      </tr>
     
      <% @services.each do |service| %>
        <tr>
          <td><%= link_to service.name, edit_service_path(service), title: 'Edit Service Entry' %></td>
          <td><%= service.short_name %></td>
          <td><%= if service.language then service.language.name else "All" end %></td>
        </tr>
      <% end %>
    </table>
  </div>
  <div class="one-third column">
    <%= link_to fa_icon("plus") + ' Add New', new_service_path, class: 'button button-primary u-full-width', title: 'Add a new service' %>
    <%= link_to fa_icon("chevron-left") + " Back", settings_path, class: 'button u-full-width', title: 'Back to Settings' %>
    <p>Services are shortcuts from within this website to interact with another website. In most cases these services will be dictionaries, translation services or similar things than can then be rapidly accessed when you are working on your text.</p>
  </div>
</div>
