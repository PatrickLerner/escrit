doctype html
html
  head
    title= page_title.html_safe
    meta name="keywords" content="language learning"
    meta name="author"   content="Patrick Lerner"
    meta name="viewport" content="width=device-width, initial-scale=1"
    = stylesheet_link_tag    "https://fonts.googleapis.com/css?family=Ubuntu:400,500,400italic,300&subset=latin,cyrillic"
    = stylesheet_link_tag    "application", media: 'all', 'data-turbolinks-track': true
    = javascript_include_tag "application", 'data-turbolinks-track': true
    = csrf_meta_tags
    = favicon_link_tag 'favicon.png'
  body
    - if Rails.env.development?
      div class="corner-ribbon top-left dark-blue sticky shadow" Dev Version
    nav.navbar
      .container
        - lang = ''
        - if current_language
          - lang = '/' + current_language.name.downcase
        - if @text and @text.language
          - lang = '/' + @text.language.name.downcase
        - if controller_name == 'texts' and action_name == 'index'
          - text_url = '/texts'
        - else
          - text_url = '/texts' + lang
        input#show-menu type="checkbox" role="button"
        label.show-menu for="show-menu" Show Menu
        ul#menu
          li= link_to image_tag('logo-i.png', class: 'navbar-logo'), '/'
          - if user_signed_in?
            li= link_to 'Home', '/home'
            li
              = link_to 'Reading ￬', text_url
              ul.hidden
                li= link_to fa_icon('book') + ' Text', text_url
                - #li= link_to fa_icon('magic') + ' Quick Reader', "/reader#{lang}"
                li= link_to fa_icon('bar-chart') + ' Statistics', "/statistics#{lang}"
                - #li= link_to fa_icon('list') + ' Word List', "/words#{lang}"
            li.right
              = link_to 'Patrick ￬', "/u/#{current_user.id}"
              ul.hidden
                li= link_to fa_icon('user') + ' Your Profile', "/u/#{current_user.id}"
                li= link_to fa_icon('wrench') + ' Settings', '/settings'
                li= link_to fa_icon('life-ring') + ' Help', '/help'
                li= link_to fa_icon('sign-out') + ' Sign Out', destroy_user_session_path, method: :delete
          - else
            li= link_to 'Sign In', new_user_session_path
            li= link_to 'Sign Up', new_user_registration_path
    - if notice
      p.notice
        = notice
    - if alert
      p.alert
        = alert
    = yield
    footer
      = link_to 'Cookie Policy', '/cookies'
      = link_to 'Legal Disclosure', '/legal'
      div &copy; 2015 escrit.eu
    - if Rails.env.production?
      = render 'layouts/footer'
