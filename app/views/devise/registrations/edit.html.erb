<h5>Edit User Profile</h5>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <div class="row">
    <div class="two-thirds column">
      <% if @user.errors.any? %>
        <div id="error_explanation">
          <h5>
            <%= pluralize(@user.errors.count, "error") %> prohibited your changes from being saved:
          </h5>
          <ul>
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= f.label :name %>
      <%= f.text_field :name, autofocus: true, class: "u-full-width" %>

      <%= f.label :about %>
      <%= f.text_area :about, placeholder: "About Me", style: 'height: 8em;', :class => 'u-full-width' %>

      <%= f.label :email %>
      <%= f.email_field :email, class: "u-full-width" %>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div>Currently waiting confirmation for: <%= resource.unconfirmed_email %></div>
      <% end %>

      <%= f.label :password %> <i>(leave blank if you don't want to change it)</i><br />
      <%= f.password_field :password, autocomplete: "off", class: "u-full-width" %>

      <%= f.label :password_confirmation %>
      <%= f.password_field :password_confirmation, autocomplete: "off", class: "u-full-width" %>

      <%= f.label :current_password %> <i>(we need your current password to confirm your changes)</i><br />
      <%= f.password_field :current_password, autocomplete: "off", class: "u-full-width" %>

      <label>Profile Picture</label>
      <p>To change your profile picture, please go to <a href="https://gravatar.com/">Gravatar</a> and register with the email address you have set in your user profile.</p>
    </div>
    <div class="one-third column">
      <%= f.submit "Update Profile", class: "u-full-width button-primary" %>
      <%= link_to fa_icon("chevron-left") + " Back", settings_path, class: 'button u-full-width', title: 'Back to Settings' %>
    </div>
  </div>
<% end %>
