<% content_for :title, 'Sign Up' %>

<h4>Sign up</h4>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <div class="row">
    <div class="two-thirds column">
      <% if @user.errors.any? %>
        <div id="error_explanation">
          <h5>
            <%= pluralize(@user.errors.count, "error") %> prohibited your changes from being saved:
          </h5>
          <ul>
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= f.label :name %>
      <%= f.text_field :name, autofocus: true, class: "u-full-width" %>

      <%= f.label :email %>
      <%= f.email_field :email, autofocus: true, class: "u-full-width" %>

      <%= f.label :password %>
      <% if @validatable %>
      <em>(<%= @minimum_password_length %> characters minimum)</em>
      <% end %>
      <%= f.password_field :password, autocomplete: "off", class: "u-full-width" %>

      <%= f.label :password_confirmation %>
      <%= f.password_field :password_confirmation, autocomplete: "off", class: "u-full-width" %>
    </div>
    <div class="one-third column">
      <%= f.submit "Sign up", class: "button-primary u-full-width" %>
      <%= render "devise/shared/links" %>
    </div>
  </div>
<% end %>

