<script type="text/javascript">
  var langs = [<%= (["'languages'"] * 5 + @languages.map {|l| "'#{l.name}'" }).join(',').html_safe %>];
  var lang_override = '';
  var lang_i = 0;

  function changeLanguage() {
    if (lang_override == '') {
      lang_i += 1;
      if (lang_i == langs.length)
        lang_i = 0;
      if ($('#lang_name').html() != langs[lang_i])
        $('#lang_name').fadeOut(1000, function() {
          $('#lang_name').html(langs[lang_i]).fadeIn(1000);
        });
    }
    setTimeout(changeLanguage, 3000);
  }
  changeLanguage();

  $('.flag')
    .mouseenter(function() {
      var lang = $(this).attr('title');
      lang_override = lang;
      $('#lang_name').fadeOut(300, function() {
        $('#lang_name').html(lang).fadeIn(300);
      })
      lang_i = 0;
    })
    .mouseleave(function() {
      lang_override = '';
    });


  for (var i = <%= max_tab_id %>; i > 0; i--) {
    $('.row[data-tab-id=' + i + ']').hide();
  }

  $('.tab-next').click(function () {
    var id = $(this).attr('data-tab-id');
    $('.row[data-tab-id=' + id + ']').hide();
    if (id == <%= max_tab_id %>)
      id = -1;
    $('.row[data-tab-id=' + (id*1+1) + ']').show();
  });

  $('.tab-previous').click(function () {
    var id = $(this).attr('data-tab-id');
    $('.row[data-tab-id=' + id + ']').hide();
    if (id == 0)
      id = <%= max_tab_id %> + 1;
    $('.row[data-tab-id=' + (id*1-1) + ']').show();
  });
</script>
